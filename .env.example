# ===========================
# 必填
# ===========================

# PostgreSQL 连接字符串
DATABASE_URL=postgresql://user:password@localhost:5432/elyhub

# Better Auth 会话签名密钥（任意随机字符串，生产环境请使用足够长的随机值）
# 生成示例：openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# ===========================
# 可选（生产环境建议配置）
# ===========================

# 应用部署 URL，用于 Better Auth 回调和跨域校验
# 默认：http://localhost:3000
BETTER_AUTH_URL=https://your-domain.com

# ===========================
# Worker 集成（按需配置）
# ===========================

# QQ Worker 鉴权 Token
# 配置后可在管理后台启用 QQ 平台 Worker
QQ_WORKER_SECRET=

# 微信 Worker 鉴权 Token
# 配置后可在管理后台启用微信平台 Worker
WECHAT_WORKER_SECRET=
